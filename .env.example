# ── Database (Railway PostgreSQL — campaigns, sessions, bookings) ─────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── INFORU — Minhelet business line ──────────────────────────────────────────
INFORU_USERNAME=hemichaeli
INFORU_PASSWORD=your_inforu_password
INFORU_BUSINESS_LINE=your_minhelet_whatsapp_number   # Minhelet's WhatsApp sender

# ── Zoho CRM (residents / buildings / compounds — read only) ──────────────────
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token

# ── Google Calendar (appointment slots) ───────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}   # JSON stringified
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=production
BASE_URL=https://minhelet-bot.up.railway.app   # Used for booking links
