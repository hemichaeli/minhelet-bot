{
  "name": "minhelet-bot",
  "version": "1.0.0",
  "description": "Minhelet Scheduling Bot — WhatsApp appointment coordination for Pinuy-Binuy residents (appraiser / surveyor / signing ceremony)",
  "main": "src/index.js",
  "scripts": {
    "start": "node -e \"require('./src/db/migrate').runMigrations().then(()=>{require('child_process').spawn('node',['src/index.js'],{stdio:'inherit'})})\"",
    "dev": "nodemon src/index.js",
    "migrate": "node-pg-migrate -m migrations --no-check-order"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
